# ============================================================
# .env.template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ============================================================

# ── Airflow internals ────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_WEBSERVER_SECRET_KEY=REPLACE_WITH_RANDOM_HEX_32

# ── Azure Blob Storage ───────────────────────────────────────────────────
# Find in: Azure Portal → Storage Account → Access keys
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
BLOB_ACCOUNT_NAME=your_storage_account_name
BLOB_ACCOUNT_KEY=your_storage_account_key

# Container names (must exist in your storage account)
BLOB_CONTAINER_RAW=raw-transactions
BLOB_CONTAINER_CLEAN=cleaned-transactions

# Folder prefix inside the raw container to watch for new CSVs
BLOB_PREFIX=dubai/

# ── Azure Synapse Analytics ──────────────────────────────────────────────
# Dedicated SQL pool endpoint
# Find in: Azure Portal → Synapse workspace → Dedicated SQL pool → Connection strings
SYNAPSE_SERVER=your-workspace.sql.azuresynapse.net
SYNAPSE_DATABASE=DubaiDW
SYNAPSE_USERNAME=your_synapse_user
SYNAPSE_PASSWORD=your_synapse_password

# ── Email notifications ──────────────────────────────────────────────────
# SMTP settings (example uses Gmail; adjust for Office 365 / SendGrid / etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_MAIL_FROM=your_email@gmail.com

# Comma-separated list of recipients
NOTIFY_EMAIL=recipient1@example.com,recipient2@example.com
