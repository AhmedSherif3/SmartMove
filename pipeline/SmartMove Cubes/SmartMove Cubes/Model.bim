            "name": "no_of_parties_role_2",
            "dataType": "string",
            "sourceColumn": "no_of_parties_role_2"
          }
        ],
        "partitions": [
          {
            "name": "Partition",
            "dataView": "full",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #\"SQL/smartmove-sql-server database windows net;smartmove-global\",",
                "    dbo_fact_transactions_england = Source{[Schema=\"dbo\",Item=\"fact_transactions_england\"]}[Data]",
                "in",
                "    dbo_fact_transactions_england"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "YoY Price Growth % England",
            "expression": [
              "",
              "VAR PrevYear =",
              "    CALCULATE(",
              "        [Avg Price per sqm England],",
              "        SAMEPERIODLASTYEAR(dim_date[full_date])",
              "    )",
              "RETURN",
              "DIVIDE([Avg Price per sqm England] - PrevYear, PrevYear) * 100"
            ]
          },
          {
            "name": "Transaction Count England",
            "expression": [
              "",
              "COUNTROWS(fact_transactions_england)"
            ]
          },
          {
            "name": "Total Sales Value England",
            "expression": [
              "",
              "SUM(fact_transactions_england[actual_worth])"
            ]
          },
          {
            "name": "Avg Ticket Size England",
            "expression": [
              "",
              "AVERAGE(fact_transactions_england[actual_worth])"
            ]
          },
          {
            "name": "Avg Price per sqm England",
            "expression": [
              "",
              "-- Note: 'meter_sale_price' is not visible in the England schema image. ",
              "-- If it doesn't exist, replace this with: ",
              "-- AVERAGEX(fact_transactions_england, DIVIDE(fact_transactions_england[actual_worth], fact_transactions_england[procedure_area]))",
              "AVERAGE(fact_transactions_england[meter_sale_price])Avg Price per sqm England:=",
              "-- Note: 'meter_sale_price' is not visible in the England schema image. ",
              "-- If it doesn't exist, replace this with: ",
              "-- AVERAGEX(fact_transactions_england, DIVIDE(fact_transactions_england[actual_worth], fact_transactions_england[procedure_area]))",
              "AVERAGE(fact_transactions_england[meter_sale_price])"
            ]
          },
          {
            "name": "Avg Procedure Area England",
            "expression": [
              "",
              "AVERAGE(fact_transactions_england[procedure_area])"
            ]
          },
          {
            "name": "Total Sales by Area England",
            "expression": [
              " ",
              "CALCULATE(",
              "    SUM(fact_transactions_england[actual_worth]),",
              "    RELATEDTABLE(dim_area_england)",
              ")"
            ]
          },
          {
            "name": "Active Areas England",
            "expression": " DISTINCTCOUNT(fact_transactions_england[area_id])"
          },
          {
            "name": "YoY Sales Growth % England",
            "expression": [
              " ",
              "VAR CurrentYear = MAX('dim_date'[year])",
              "VAR CurrentSales = [Total Sales Value England]",
              "VAR PrevYearSales = ",
              "    CALCULATE(",
              "        [Total Sales Value England],",
              "        ALL('dim_date'), ",
              "        'dim_date'[year] = CurrentYear - 1",
              "    )",
              "VAR NextYearSales = ",
              "    CALCULATE(",
              "        [Total Sales Value England],",
              "        ALL('dim_date'), ",
              "        'dim_date'[year] = CurrentYear + 1",
              "    )",
              "RETURN",
              "    SWITCH(",
              "        TRUE(),",
              "        -- 1. The year BEFORE data starts: Force to 0 to anchor the line.",
              "        ISBLANK(CurrentSales) && NOT ISBLANK(NextYearSales), 0,",
              "        ",
              "        -- 2. The FIRST year of data: Force to 100% to make the line go \"up\".",
              "        NOT ISBLANK(CurrentSales) && ISBLANK(PrevYearSales), 100,",
              "        ",
              "        -- 3. All normal years: Do the actual math.",
              "        NOT ISBLANK(CurrentSales), DIVIDE(CurrentSales - PrevYearSales, PrevYearSales) * 100,",
              "        ",
              "        -- 4. Future/Past years with no data around them stay blank",
              "        BLANK()",
              "    )"
            ]
          },
          {
            "name": "Sales per Month England",
            "expression": [
              "",
              "-- Note: Requires a 'YearMonth' column in dim_date",
              "VAR MonthsInContext = DISTINCTCOUNT(dim_date[YearMonth])",
              "RETURN DIVIDE([Transaction Count England], MonthsInContext)"
            ]
          },
          {
            "name": "New Transaction Count England",
            "expression": [
              "",
              "CALCULATE(",
              "    [Transaction Count England],",
              "    dim_registration_england[reg_type_en] = \"New\"",
              ")"
            ]
          },
          {
            "name": "New Property Ratio England",
            "expression": [
              "",
              "DIVIDE([New Transaction Count England], [Transaction Count England])"
            ]
          },
          {
            "name": "Sales per Year England",
            "expression": [
              " ",
              "VAR YearsInContext = DISTINCTCOUNT(dim_date[year])",
              "RETURN DIVIDE([Transaction Count England], YearsInContext)"
            ]
          },
          {
            "name": "Property Types England",
            "expression": " DISTINCTCOUNT(fact_transactions_england[property_type_id])"
          },
          {
            "name": "Investment Score England",
            "expression": [
              " ",
              "VAR growth_score =",
              "    DIVIDE([YoY Price Growth % England], ",
              "           MAXX(ALL(dim_area_england[area_name_en]), [YoY Price Growth % England]))",
              "VAR liquidity_score =",
              "    DIVIDE([Liquidity (Sales/Month) England], ",
              "           MAXX(ALL(dim_area_england[area_name_en]), [Liquidity (Sales/Month) England]))",
              "VAR capital_score =",
              "    DIVIDE([Capital Growth % England], ",
              "           MAXX(ALL(dim_area_england[area_name_en]), [Capital Growth % England]))",
              "VAR risk_penalty =",
              "    1 - DIVIDE([Risk Score England], ",
              "               MAXX(ALL(dim_area_england[area_name_en]), [Risk Score England]))",
              "RETURN",
              "    (growth_score * 0.35) +",
              "    (liquidity_score * 0.25) +",
              "    (capital_score * 0.25) +",
              "    (risk_penalty * 0.15)"
            ]
          },
          {
            "name": "MoM Price Momentum % England",
            "expression": [
              "",
              "VAR PrevMonth =",
              "    CALCULATE(",
              "        [Avg Price per sqm England],",
              "        PARALLELPERIOD(dim_date[full_date], -1, MONTH)",
              "    )",
              "RETURN",
              "    DIVIDE([Avg Price per sqm England] - PrevMonth, PrevMonth)"
            ]
          },
          {
            "name": "Liquidity (Sales/Month) England",
            "expression": [
              "",
              "[Sales per Month England]"
            ]
          },
          {
            "name": "Tx Count 6M Avg England",
            "expression": [
              "",
              "AVERAGEX(",
              "    DATESINPERIOD(dim_date[full_date], MAX(dim_date[full_date]), -6, MONTH),",
              "    CALCULATE([Transaction Count England])",
              ")Tx Count 6M Avg England:=",
              "AVERAGEX(",
              "    DATESINPERIOD(dim_date[full_date], MAX(dim_date[full_date]), -6, MONTH),",
              "    CALCULATE([Transaction Count England])",
              ")"
            ]
          },
          {
            "name": "Volume Spike % England",
            "expression": [
              "",
              "DIVIDE([Transaction Count England] - [Tx Count 6M Avg England], [Tx Count 6M Avg England])"
            ]
          },
          {
            "name": "Heat Index England",
            "expression": [
              "",
              "0.35 * [MoM Price Momentum % England] +",
              "0.35 * [YoY Price Growth % England] +",
              "0.20 * [Liquidity (Sales/Month) England] +",
              "0.10 * [Volume Spike % England]"
            ]
          },
          {
            "name": "Risk Score England",
            "expression": [
              " ",
              "VAR RawScore = ",
              "    (0.45 * [Price Volatility 6M England]) + ",
              "    (0.35 * [Outlier Transaction Ratio England]) + ",
              "    (0.20 * [Shock Index England])",
              "VAR MaxScoreInMarket = ",
              "    MAXX(",
              "        ALLSELECTED('dim_area_england'), ",
              "        (0.45 * [Price Volatility 6M England]) + ",
              "        (0.35 * [Outlier Transaction Ratio England]) + ",
              "        (0.20 * [Shock Index England])",
              "    )",
              "RETURN ",
              "    DIVIDE(RawScore, MaxScoreInMarket, 0)"
            ]
          },
          {
            "name": "Show In Chart England",
            "expression": [
              " ",
              "VAR highest = [Top 5 Highest Risk Score England]",
              "VAR lowest = [Top 5 Lowest Risk Score England]",
              "VAR raw =",
              "    (0.45 * [Price Volatility 6M England]) +",
              "    (0.35 * [Outlier Transaction Ratio England]) +",
              "    (0.20 * [Shock Index England])",
              "RETURN",
              "    IF(",
              "        (NOT ISBLANK(highest) || NOT ISBLANK(lowest)) && raw > 0,",
              "        1,",
              "        BLANK()",
              "    )"
            ]
          },
          {
            "name": "Top 5 Combined Risk England",
            "expression": [
              " ",
              "VAR highest = [Top 5 Highest Risk Score England]",
              "VAR lowest = [Top 5 Lowest Risk Score England]",
              "RETURN",
              "    IF(",
              "        NOT ISBLANK(highest) || NOT ISBLANK(lowest),",
              "        1,",
              "        BLANK()",
              "    )"
            ]
          },
          {
            "name": "Top 5 Highest Risk Score England",
            "expression": [
              " ",
              "VAR RawScore =",
              "    (0.45 * [Price Volatility 6M England]) +",
              "    (0.35 * [Outlier Transaction Ratio England]) +",
              "    (0.20 * [Shock Index England])",
              "VAR MaxScoreInMarket =",
              "    MAXX(",
              "        ALLSELECTED('dim_area_england'),",
              "        (0.45 * [Price Volatility 6M England]) +",
              "        (0.35 * [Outlier Transaction Ratio England]) +",
              "        (0.20 * [Shock Index England])",
              "    )",
              "VAR NormalizedScore =",
              "    DIVIDE(RawScore, MaxScoreInMarket, 0)",
              "VAR CurrentAreaRank =",
              "    RANKX(",
              "        FILTER(",
              "            ALLSELECTED('dim_area_england'),",
              "            (0.45 * [Price Volatility 6M England]) +",
              "            (0.35 * [Outlier Transaction Ratio England]) +",
              "            (0.20 * [Shock Index England]) > 0",
              "        ),",
              "        DIVIDE(",
              "            (0.45 * [Price Volatility 6M England]) +",
              "            (0.35 * [Outlier Transaction Ratio England]) +",
              "            (0.20 * [Shock Index England]),",
              "            MaxScoreInMarket,",
              "            0",
              "        ),",
              "        ,",
              "        DESC,",
              "        DENSE",
              "    )",
              "RETURN",
              "    IF(RawScore > 0 && CurrentAreaRank <= 5, NormalizedScore, BLANK())"
            ]
          },
          {
            "name": "Top 5 Lowest Risk Score England",
            "expression": [
              " ",
              "VAR RawScore =",
              "    (0.45 * [Price Volatility 6M England]) +",
              "    (0.35 * [Outlier Transaction Ratio England]) +",
              "    (0.20 * [Shock Index England])",
              "VAR MaxScoreInMarket =",
              "    MAXX(",
              "        ALLSELECTED('dim_area_england'),",
              "        (0.45 * [Price Volatility 6M England]) +",
              "        (0.35 * [Outlier Transaction Ratio England]) +",
              "        (0.20 * [Shock Index England])",
              "    )",
              "VAR NormalizedScore =",
              "    DIVIDE(RawScore, MaxScoreInMarket, 0)",
              "VAR ValidAreas =",
              "    FILTER(",
              "        ALLSELECTED('dim_area_england'),",
              "        NOT ISBLANK([Price Volatility 6M England]) &&",
              "        NOT ISBLANK([Shock Index England])",
              "    )",
              "VAR CurrentAreaRank =",
              "    RANKX(",
              "        ValidAreas,",
              "        DIVIDE(",
              "            (0.45 * [Price Volatility 6M England]) +",
              "            (0.35 * [Outlier Transaction Ratio England]) +",
              "            (0.20 * [Shock Index England]),",
              "            MaxScoreInMarket,",
              "            0",
              "        ),",
              "        ,",
              "        ASC,",
              "        DENSE",
              "    )",
              "RETURN",
              "    IF(",
              "        NOT ISBLANK([Price Volatility 6M England]) &&",
              "        NOT ISBLANK([Shock Index England]) &&",
              "        CurrentAreaRank <= 5,",
              "        NormalizedScore,",
              "        BLANK()",
              "    )"
            ]
          },
          {
            "name": "Top N Areas Filter England",
            "expression": [
              " ",
              "VAR selected_n = SELECTEDVALUE('Top N'[N], 10)",
              "VAR area_rank =",
              "    RANKX(",
              "        ALL(dim_area_england[area_name_en]),",
              "        [Investor Score England],",
              "        ,",
              "        DESC,",
              "        DENSE",
              "    )",
              "RETURN",
              "    IF(area_rank <= selected_n, 1, 0)"
            ]
          },
          {
            "name": "Turnover Velocity England",
            "expression": [
              "",
              "[Sales per Month England]"
            ]
          },
          {
            "name": "Capital Growth % England",
            "expression": [
              "",
              "[YoY Price Growth % England]"
            ]
          },
          {
            "name": "Monthly Avg Price per sqm England",
            "expression": [
              "",
              "CALCULATE([Avg Price per sqm England])"
            ]
          },
          {
            "name": "Price Volatility 6M England",
            "expression": [
              "",
              "-- Note: Requires a 'YearMonth' column in dim_date",
              "VAR Window =",
              "    DATESINPERIOD(dim_date[full_date], MAX(dim_date[full_date]), -6, MONTH)",
              "RETURN",
              "STDEVX.S(",
              "    VALUES(dim_date[YearMonth]),",
              "    CALCULATE([Monthly Avg Price per sqm England], Window)",
              ")"
            ]
          },
          {
            "name": "Risk-Adjusted Opportunity Score England",
            "expression": [
              "",
              "DIVIDE(",
              "    [Capital Growth % England] * [Turnover Velocity England],",
              "    [Price Volatility 6M England]",
              ")"
            ]
          },
          {
            "name": "Investor Score England",
            "expression": " 0.80 * [Risk-Adjusted Opportunity Score England] + 0.20 * DIVIDE([Avg Ticket Size England], 5000000)"
          },
          {
            "name": "Avg Capital Growth % England",
            "expression": [
              " ",
              "-- Note: Requires a 'YearMonth' column in dim_date",
              "AVERAGEX(VALUES(dim_date[YearMonth]), [Capital Growth % England])"
            ]
          },
          {
            "name": "Median Turnover Velocity England",
            "expression": " MEDIANX(VALUES(dim_area_england[area_name_en]), [Turnover Velocity England])"
          },
          {
            "name": "Avg Price per sqm 6M England",
            "expression": [
              "",
              "AVERAGEX(",
              "    DATESINPERIOD(dim_date[full_date], MAX(dim_date[full_date]), -6, MONTH),",
              "    CALCULATE([Avg Price per sqm England])",
              ")"
            ]
          },
          {
            "name": "Shock Index England",
            "expression": [
              "",
              "DIVIDE([Avg Price per sqm England] - [Avg Price per sqm 6M England], [Avg Price per sqm 6M England])"
            ]
          },
          {
            "name": "Outlier Transaction Ratio England",
            "expression": [
              "",
              "VAR mu = [Avg Price per sqm England]",
              "VAR sigma =",
              "    CALCULATE(",
              "        STDEVX.S(",
              "            fact_transactions_england,",
              "            -- Update this column reference if you calculate price per meter dynamically",
              "            fact_transactions_england[meter_sale_price] ",
              "        )",
              "    )",
              "VAR threshold = mu + 2 * sigma",
              "VAR outliers =",
              "    CALCULATE(",
              "        [Transaction Count England],",
              "        FILTER(",
              "            fact_transactions_england,",
              "            fact_transactions_england[meter_sale_price] > threshold",
              "        )",
              "    )",
              "RETURN",
              "    DIVIDE(outliers, [Transaction Count England])"
            ]
          },
          {
            "name": "Outlier Transaction Ratio % England",
            "expression": [
              "",
              "VAR mu = [Avg Price per sqm England]",
              "VAR sigma =",
              "    CALCULATE(",
              "        STDEVX.S(",
              "            fact_transactions_england,",
              "            fact_transactions_england[meter_sale_price]",
              "        )",
              "    )",
              "VAR threshold = mu + 2 * sigma",
              "VAR outliers =",
              "    CALCULATE(",
              "        [Transaction Count England],",
              "        FILTER(",
              "            fact_transactions_england,",
              "            fact_transactions_england[meter_sale_price] > threshold",
              "        )",
              "    )",
              "RETURN",
              "    FORMAT(DIVIDE(outliers, [Transaction Count England]), \"0.00%\")"
            ]
          }
        ]
      },
