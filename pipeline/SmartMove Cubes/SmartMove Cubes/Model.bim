        "partitions": [
          {
            "name": "Partition",
            "dataView": "full",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #\"SQL/smartmove-sql-server database windows net;smartmove-global\",",
                "    dbo_fact_transactions_dubai = Source{[Schema=\"dbo\",Item=\"fact_transactions_dubai\"]}[Data]",
                "in",
                "    dbo_fact_transactions_dubai"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "YoY Price Growth %",
            "expression": [
              "",
              "",
              "VAR PrevYear =",
              "",
              "    CALCULATE(",
              "",
              "        [Avg Price per sqm],",
              "",
              "        SAMEPERIODLASTYEAR(dim_date_dubai[full_date])",
              "",
              "    )",
              "",
              "RETURN",
              "",
              "DIVIDE([Avg Price per sqm] - PrevYear, PrevYear) * 100"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Transaction Count",
            "expression": [
              "",
              "COUNTROWS(fact_transactions_dubai)",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Total Sales Value",
            "expression": [
              "",
              "SUM(fact_transactions_dubai[actual_worth])",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Avg Ticket Size",
            "expression": [
              "",
              "AVERAGE(fact_transactions_dubai[actual_worth])"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Avg Price per sqm",
            "expression": [
              "",
              "AVERAGE(fact_transactions_dubai[meter_sale_price])",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Avg Procedure Area",
            "expression": [
              "",
              "AVERAGE(fact_transactions_dubai[procedure_area])",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Total Sales by Area",
            "expression": [
              " ",
              "CALCULATE(",
              "    SUM(fact_transactions_dubai[actual_worth]),",
              "    RELATEDTABLE(dim_area_dubai)",
              ")",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Active Areas",
            "expression": [
              " DISTINCTCOUNT(fact_transactions_dubai[area_id])",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "YoY Sales Growth %",
            "expression": [
              " ",
              "VAR CurrentYear = MAX('dim_date_dubai'[year])",
              "VAR CurrentSales = [Total Sales Value]",
              "",
              "VAR PrevYearSales = ",
              "    CALCULATE(",
              "        [Total Sales Value],",
              "        ALL('dim_date_dubai'), ",
              "        'dim_date_dubai'[year] = CurrentYear - 1",
              "    )",
              "",
              "VAR NextYearSales = ",
              "    CALCULATE(",
              "        [Total Sales Value],",
              "        ALL('dim_date_dubai'), ",
              "        'dim_date_dubai'[year] = CurrentYear + 1",
              "    )",
              "",
              "RETURN",
              "    SWITCH(",
              "        TRUE(),",
              "        -- 1. The year BEFORE data starts: Force to 0 to anchor the line.",
              "        ISBLANK(CurrentSales) && NOT ISBLANK(NextYearSales), 0,",
              "        ",
              "        -- 2. The FIRST year of data: Force to 100% to make the line go \"up\".",
              "        NOT ISBLANK(CurrentSales) && ISBLANK(PrevYearSales), 100,",
              "        ",
              "        -- 3. All normal years: Do the actual math.",
              "        NOT ISBLANK(CurrentSales), DIVIDE(CurrentSales - PrevYearSales, PrevYearSales) * 100,",
              "        ",
              "        -- 4. Future/Past years with no data around them stay blank",
              "        BLANK()",
              "    )",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Sales per Month",
            "expression": [
              "",
              "VAR MonthsInContext = DISTINCTCOUNT(dim_date_dubai[YearMonth])",
              "RETURN DIVIDE([Transaction Count], MonthsInContext)"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "New Transaction Count",
            "expression": [
              "",
              "CALCULATE(",
              "    [Transaction Count],",
              "    dim_registration_dubai[reg_type_en] = \"New\"",
              ")",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "New Property Ratio",
            "expression": [
              "",
              "DIVIDE([New Transaction Count], [Transaction Count])",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Sales per Year",
            "expression": [
              " ",
              "VAR YearsInContext = DISTINCTCOUNT(dim_date_dubai[year])",
              "RETURN DIVIDE([Transaction Count], YearsInContext)",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Property Types",
            "expression": [
              " DISTINCTCOUNT(fact_transactions_dubai[property_type_id])",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Investment Score",
            "expression": [
              " ",
              "VAR growth_score =",
              "    DIVIDE([YoY Price Growth %], ",
              "           MAXX(ALL(dim_area_dubai[area_name_en]), [YoY Price Growth %]))",
              "",
              "VAR liquidity_score =",
              "    DIVIDE([Liquidity (Sales/Month)], ",
              "           MAXX(ALL(dim_area_dubai[area_name_en]), [Liquidity (Sales/Month)]))",
              "",
              "VAR capital_score =",
              "    DIVIDE([Capital Growth %], ",
              "           MAXX(ALL(dim_area_dubai[area_name_en]), [Capital Growth %]))",
              "",
              "VAR risk_penalty =",
              "    1 - DIVIDE([Risk Score (Dubai)], ",
              "               MAXX(ALL(dim_area_dubai[area_name_en]), [Risk Score (Dubai)]))",
              "",
              "RETURN",
              "    (growth_score * 0.35) +",
              "    (liquidity_score * 0.25) +",
              "    (capital_score * 0.25) +",
              "    (risk_penalty * 0.15)",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "MoM Price Momentum %",
            "expression": [
              "",
              "VAR PrevMonth =",
              "    CALCULATE(",
              "        [Avg Price per sqm],",
              "        PARALLELPERIOD(dim_date_dubai[full_date], -1, MONTH)",
              "    )",
              "RETURN",
              "    DIVIDE([Avg Price per sqm] - PrevMonth, PrevMonth)",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Liquidity (Sales/Month)",
            "expression": [
              " [Sales per Month]",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Tx Count 6M Avg",
            "expression": [
              "",
              "AVERAGEX(",
              "    DATESINPERIOD(dim_date_dubai[full_date], MAX(dim_date_dubai[full_date]), -6, MONTH),",
              "    CALCULATE([Transaction Count])",
              ")",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Volume Spike %",
            "expression": [
              "",
              "DIVIDE([Transaction Count] - [Tx Count 6M Avg], [Tx Count 6M Avg])",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Heat Index (Dubai)",
            "expression": [
              "",
              "0.35 * [MoM Price Momentum %] +",
              "0.35 * [YoY Price Growth %] +",
              "0.20 * [Liquidity (Sales/Month)] +",
              "0.10 * [Volume Spike %]",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Risk Score",
            "expression": [
              " ",
              "VAR RawScore = ",
              "    (0.45 * [Price Volatility 6M]) + ",
              "    (0.35 * [Outlier Transaction Ratio]) + ",
              "    (0.20 * [Shock Index])",
              "",
              "-- This finds the highest raw score across all areas to use as a ceiling",
              "VAR MaxScoreInMarket = ",
              "    MAXX(",
              "        ALLSELECTED('dim_area_dubai'), ",
              "        (0.45 * [Price Volatility 6M]) + ",
              "        (0.35 * [Outlier Transaction Ratio]) + ",
              "        (0.20 * [Shock Index])",
              "    )",
              "",
              "RETURN ",
              "    DIVIDE(RawScore, MaxScoreInMarket, 0)",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Show In Chart",
            "expression": [
              " ",
              "VAR highest = [Top 5 Highest Risk Score (Dubai)]",
              "VAR lowest = [Top 5 Lowest Risk Score (Dubai)]",
              "VAR raw =",
              "    (0.45 * [Price Volatility 6M]) +",
              "    (0.35 * [Outlier Transaction Ratio]) +",
              "    (0.20 * [Shock Index])",
              "RETURN",
              "    IF(",
              "        (NOT ISBLANK(highest) || NOT ISBLANK(lowest)) && raw > 0,",
              "        1,",
              "        BLANK()",
              "    )",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Top 5 Combined Risk",
            "expression": [
              " ",
              "VAR highest = [Top 5 Highest Risk Score (Dubai)]",
              "VAR lowest = [Top 5 Lowest Risk Score (Dubai)]",
              "RETURN",
              "    IF(",
              "        NOT ISBLANK(highest) || NOT ISBLANK(lowest),",
              "        1,",
              "        BLANK()",
              "    )",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Top 5 Highest Risk Score (Dubai)",
            "expression": [
              " ",
              "VAR RawScore =",
              "    (0.45 * [Price Volatility 6M]) +",
              "    (0.35 * [Outlier Transaction Ratio]) +",
              "    (0.20 * [Shock Index])",
              "",
              "VAR MaxScoreInMarket =",
              "    MAXX(",
              "        ALLSELECTED('dim_area_dubai'),",
              "        (0.45 * [Price Volatility 6M]) +",
              "        (0.35 * [Outlier Transaction Ratio]) +",
              "        (0.20 * [Shock Index])",
              "    )",
              "",
              "VAR NormalizedScore =",
              "    DIVIDE(RawScore, MaxScoreInMarket, 0)",
              "",
              "VAR CurrentAreaRank =",
              "    RANKX(",
              "        FILTER(",
              "            ALLSELECTED('dim_area_dubai'),",
              "            (0.45 * [Price Volatility 6M]) +",
              "            (0.35 * [Outlier Transaction Ratio]) +",
              "            (0.20 * [Shock Index]) > 0",
              "        ),",
              "        DIVIDE(",
              "            (0.45 * [Price Volatility 6M]) +",
              "            (0.35 * [Outlier Transaction Ratio]) +",
              "            (0.20 * [Shock Index]),",
              "            MaxScoreInMarket,",
              "            0",
              "        ),",
              "        ,",
              "        DESC,",
              "        DENSE",
              "    )",
              "",
              "RETURN",
              "    IF(RawScore > 0 && CurrentAreaRank <= 5, NormalizedScore, BLANK())",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Top 5 Lowest Risk Score (Dubai)",
            "expression": [
              " ",
              "VAR RawScore =",
              "    (0.45 * [Price Volatility 6M]) +",
              "    (0.35 * [Outlier Transaction Ratio]) +",
              "    (0.20 * [Shock Index])",
              "",
              "VAR MaxScoreInMarket =",
              "    MAXX(",
              "        ALLSELECTED('dim_area_dubai'),",
              "        (0.45 * [Price Volatility 6M]) +",
              "        (0.35 * [Outlier Transaction Ratio]) +",
              "        (0.20 * [Shock Index])",
              "    )",
              "",
              "VAR NormalizedScore =",
              "    DIVIDE(RawScore, MaxScoreInMarket, 0)",
              "",
              "VAR ValidAreas =",
              "    FILTER(",
              "        ALLSELECTED('dim_area_dubai'),",
              "        NOT ISBLANK([Price Volatility 6M]) &&",
              "        NOT ISBLANK([Shock Index])",
              "    )",
              "",
              "VAR CurrentAreaRank =",
              "    RANKX(",
              "        ValidAreas,",
              "        DIVIDE(",
              "            (0.45 * [Price Volatility 6M]) +",
              "            (0.35 * [Outlier Transaction Ratio]) +",
              "            (0.20 * [Shock Index]),",
              "            MaxScoreInMarket,",
              "            0",
              "        ),",
              "        ,",
              "        ASC,",
              "        DENSE",
              "    )",
              "",
              "RETURN",
              "    IF(",
              "        NOT ISBLANK([Price Volatility 6M]) &&",
              "        NOT ISBLANK([Shock Index]) &&",
              "        CurrentAreaRank <= 5,",
              "        NormalizedScore,",
              "        BLANK()",
              "    )",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Top N Areas Filter",
            "expression": [
              " ",
              "VAR selected_n = SELECTEDVALUE('Top N'[N], 10)",
              "VAR area_rank =",
              "    RANKX(",
              "        ALL(dim_area_dubai[area_name_en]),",
              "        [Investor Score (Dubai)],",
              "        ,",
              "        DESC,",
              "        DENSE",
              "    )",
              "RETURN",
              "    IF(area_rank <= selected_n, 1, 0)",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Turnover Velocity",
            "expression": [
              " [Sales per Month]",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Capital Growth %",
            "expression": [
              "",
              "[YoY Price Growth %]",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Monthly Avg Price per sqm",
            "expression": [
              "",
              "CALCULATE([Avg Price per sqm])",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Price Volatility 6M",
            "expression": [
              "",
              "VAR Window =",
              "    DATESINPERIOD(dim_date_dubai[full_date], MAX(dim_date_dubai[full_date]), -6, MONTH)",
              "RETURN",
              "STDEVX.S(",
              "    VALUES(dim_date_dubai[YearMonth]),",
              "    CALCULATE([Monthly Avg Price per sqm], Window)",
              ")",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Risk-Adjusted Opportunity Score",
            "expression": [
              "",
              "DIVIDE(",
              "    [Capital Growth %] * [Turnover Velocity],",
              "    [Price Volatility 6M]",
              ")",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Investor Score (Dubai)",
            "expression": [
              " 0.80 * [Risk-Adjusted Opportunity Score] + 0.20 * DIVIDE([Avg Ticket Size], 5000000)",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Avg Capital Growth %",
            "expression": [
              " AVERAGEX(VALUES(dim_date_dubai[YearMonth]), [Capital Growth %])",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Median Turnover Velocity",
            "expression": [
              " MEDIANX(VALUES(dim_area_dubai[area_name_en]), [Turnover Velocity])",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Avg Price per sqm 6M",
            "expression": [
              "",
              "AVERAGEX(",
              "    DATESINPERIOD(dim_date_dubai[full_date], MAX(dim_date_dubai[full_date]), -6, MONTH),",
              "    CALCULATE([Avg Price per sqm])",
              ")",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Shock Index",
            "expression": [
              "",
              "DIVIDE([Avg Price per sqm] - [Avg Price per sqm 6M], [Avg Price per sqm 6M])",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Outlier Transaction Ratio",
            "expression": [
              "",
              "VAR mu = [Avg Price per sqm]",
              "VAR sigma =",
              "    CALCULATE(",
              "        STDEVX.S(",
              "            fact_transactions_dubai,",
              "            fact_transactions_dubai[meter_sale_price]",
              "        )",
              "    )",
              "VAR threshold = mu + 2 * sigma",
              "VAR outliers =",
              "    CALCULATE(",
              "        [Transaction Count],",
              "        FILTER(",
              "            fact_transactions_dubai,",
              "            fact_transactions_dubai[meter_sale_price] > threshold",
              "        )",
              "    )",
              "RETURN",
              "    DIVIDE(outliers, [Transaction Count])",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Risk Score (Dubai)",
            "expression": [
              " ",
              "VAR RawScore = ",
              "    (0.45 * [Price Volatility 6M]) + ",
              "    (0.35 * [Outlier Transaction Ratio]) + ",
              "    (0.20 * [Shock Index])",
              "",
              "-- This finds the highest raw score across all areas to use as a ceiling",
              "VAR MaxScoreInMarket = ",
              "    MAXX(",
              "        ALLSELECTED('dim_area_dubai'), ",
              "        (0.45 * [Price Volatility 6M]) + ",
              "        (0.35 * [Outlier Transaction Ratio]) + ",
              "        (0.20 * [Shock Index])",
              "    )",
              "",
              "RETURN ",
              "    DIVIDE(RawScore, MaxScoreInMarket, 0)",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          },
          {
            "name": "Outlier Transaction Ratio %",
            "expression": [
              "",
              "VAR mu = [Avg Price per sqm]",
              "VAR sigma =",
              "    CALCULATE(",
              "        STDEVX.S(",
              "            fact_transactions_dubai,",
              "            fact_transactions_dubai[meter_sale_price]",
              "        )",
              "    )",
              "VAR threshold = mu + 2 * sigma",
              "VAR outliers =",
              "    CALCULATE(",
              "        [Transaction Count],",
              "        FILTER(",
              "            fact_transactions_dubai,",
              "            fact_transactions_dubai[meter_sale_price] > threshold",
              "        )",
              "    )",
              "RETURN",
              "    FORMAT(DIVIDE(outliers, [Transaction Count]), \"0.00%\")",
              ""
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Dubai\"]"
              }
            ]
          }
        ]
