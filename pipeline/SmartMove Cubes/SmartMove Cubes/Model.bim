        ],
        "partitions": [
          {
            "name": "Partition",
            "dataView": "full",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #\"SQL/smartmove-sql-server database windows net;smartmove-global\",",
                "    dbo_fact_transactions_egypt = Source{[Schema=\"dbo\",Item=\"fact_transactions_egypt\"]}[Data]",
                "in",
                "    dbo_fact_transactions_egypt"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "YoY Price Growth % Egypt",
            "expression": [
              "",
              "VAR PrevYear =",
              "    CALCULATE(",
              "        [Avg Price per sqm Egypt],",
              "        SAMEPERIODLASTYEAR(dim_date_egypt[full_date])",
              "    )",
              "RETURN",
              "DIVIDE([Avg Price per sqm Egypt] - PrevYear, PrevYear) * 100"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Transaction Count Egypt",
            "expression": [
              "",
              "COUNTROWS(fact_transactions_egypt)"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Total Sales Value Egypt",
            "expression": [
              "",
              "SUM(fact_transactions_egypt[actual_worth])"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Avg Ticket Size Egypt",
            "expression": [
              "",
              "AVERAGE(fact_transactions_egypt[actual_worth])"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Avg Price per sqm Egypt",
            "expression": [
              "",
              "-- Note: 'meter_sale_price' is not visible in the schema image. ",
              "-- If it doesn't exist in the table, replace this with: ",
              "-- AVERAGEX(fact_transactions_egypt, DIVIDE(fact_transactions_egypt[actual_worth], fact_transactions_egypt[procedure_area]))",
              "AVERAGE(fact_transactions_egypt[meter_sale_price])"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Avg Procedure Area Egypt",
            "expression": [
              "",
              "AVERAGE(fact_transactions_egypt[procedure_area])"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Total Sales by Area Egypt",
            "expression": [
              " ",
              "CALCULATE(",
              "    SUM(fact_transactions_egypt[actual_worth]),",
              "    RELATEDTABLE(dim_area_egypt)",
              ")"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Active Areas Egypt",
            "expression": " DISTINCTCOUNT(fact_transactions_egypt[area_id])",
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "YoY Sales Growth % Egypt",
            "expression": [
              " ",
              "VAR CurrentYear = MAX('dim_date_egypt'[year])",
              "VAR CurrentSales = [Total Sales Value Egypt]",
              "VAR PrevYearSales = ",
              "    CALCULATE(",
              "        [Total Sales Value Egypt],",
              "        ALL('dim_date_egypt'), ",
              "        'dim_date_egypt'[year] = CurrentYear - 1",
              "    )",
              "VAR NextYearSales = ",
              "    CALCULATE(",
              "        [Total Sales Value Egypt],",
              "        ALL('dim_date_egypt'), ",
              "        'dim_date_egypt'[year] = CurrentYear + 1",
              "    )",
              "RETURN",
              "    SWITCH(",
              "        TRUE(),",
              "        -- 1. The year BEFORE data starts: Force to 0 to anchor the line.",
              "        ISBLANK(CurrentSales) && NOT ISBLANK(NextYearSales), 0,",
              "        ",
              "        -- 2. The FIRST year of data: Force to 100% to make the line go \"up\".",
              "        NOT ISBLANK(CurrentSales) && ISBLANK(PrevYearSales), 100,",
              "        ",
              "        -- 3. All normal years: Do the actual math.",
              "        NOT ISBLANK(CurrentSales), DIVIDE(CurrentSales - PrevYearSales, PrevYearSales) * 100,",
              "        ",
              "        -- 4. Future/Past years with no data around them stay blank",
              "        BLANK()",
              "    )"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Sales per Month Egypt",
            "expression": [
              "",
              "-- Note: Requires a 'YearMonth' column in dim_date_egypt",
              "VAR MonthsInContext = DISTINCTCOUNT(dim_date_egypt[YearMonth])",
              "RETURN DIVIDE([Transaction Count Egypt], MonthsInContext)"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "New Transaction Count Egypt",
            "expression": [
              "",
              "CALCULATE(",
              "    [Transaction Count Egypt],",
              "    dim_registration_egypt[reg_type_en] = \"New\"",
              ")"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "New Property Ratio Egypt",
            "expression": [
              "",
              "DIVIDE([New Transaction Count Egypt], [Transaction Count Egypt])"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Sales per Year Egypt",
            "expression": [
              " ",
              "VAR YearsInContext = DISTINCTCOUNT(dim_date_egypt[year])",
              "RETURN DIVIDE([Transaction Count Egypt], YearsInContext)"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Property Types Egypt",
            "expression": " DISTINCTCOUNT(fact_transactions_egypt[property_type_id])",
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Investment Score Egypt",
            "expression": [
              " ",
              "VAR growth_score =",
              "    DIVIDE([YoY Price Growth % Egypt], ",
              "           MAXX(ALL(dim_area_egypt[area_name_en]), [YoY Price Growth % Egypt]))",
              "VAR liquidity_score =",
              "    DIVIDE([Liquidity (Sales/Month) Egypt], ",
              "           MAXX(ALL(dim_area_egypt[area_name_en]), [Liquidity (Sales/Month) Egypt]))",
              "VAR capital_score =",
              "    DIVIDE([Capital Growth % Egypt], ",
              "           MAXX(ALL(dim_area_egypt[area_name_en]), [Capital Growth % Egypt]))",
              "VAR risk_penalty =",
              "    1 - DIVIDE([Risk Score Egypt], ",
              "               MAXX(ALL(dim_area_egypt[area_name_en]), [Risk Score Egypt]))",
              "RETURN",
              "    (growth_score * 0.35) +",
              "    (liquidity_score * 0.25) +",
              "    (capital_score * 0.25) +",
              "    (risk_penalty * 0.15)"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "MoM Price Momentum % Egypt",
            "expression": [
              "",
              "VAR PrevMonth =",
              "    CALCULATE(",
              "        [Avg Price per sqm Egypt],",
              "        PARALLELPERIOD(dim_date_egypt[full_date], -1, MONTH)",
              "    )",
              "RETURN",
              "    DIVIDE([Avg Price per sqm Egypt] - PrevMonth, PrevMonth)"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Liquidity (Sales/Month) Egypt",
            "expression": [
              "",
              "[Sales per Month Egypt]"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Tx Count 6M Avg Egypt",
            "expression": [
              "",
              "AVERAGEX(",
              "    DATESINPERIOD(dim_date_egypt[full_date], MAX(dim_date_egypt[full_date]), -6, MONTH),",
              "    CALCULATE([Transaction Count Egypt])",
              ")"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Volume Spike % Egypt",
            "expression": [
              "",
              "DIVIDE([Transaction Count Egypt] - [Tx Count 6M Avg Egypt], [Tx Count 6M Avg Egypt])"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Heat Index Egypt",
            "expression": [
              "",
              "0.35 * [MoM Price Momentum % Egypt] +",
              "0.35 * [YoY Price Growth % Egypt] +",
              "0.20 * [Liquidity (Sales/Month) Egypt] +",
              "0.10 * [Volume Spike % Egypt]"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Risk Score Egypt",
            "expression": [
              " ",
              "VAR RawScore = ",
              "    (0.45 * [Price Volatility 6M Egypt]) + ",
              "    (0.35 * [Outlier Transaction Ratio Egypt]) + ",
              "    (0.20 * [Shock Index Egypt])",
              "VAR MaxScoreInMarket = ",
              "    MAXX(",
              "        ALLSELECTED('dim_area_egypt'), ",
              "        (0.45 * [Price Volatility 6M Egypt]) + ",
              "        (0.35 * [Outlier Transaction Ratio Egypt]) + ",
              "        (0.20 * [Shock Index Egypt])",
              "    )",
              "RETURN ",
              "    DIVIDE(RawScore, MaxScoreInMarket, 0)"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Show In Chart Egypt",
            "expression": [
              " ",
              "VAR highest = [Top 5 Highest Risk Score Egypt]",
              "VAR lowest = [Top 5 Lowest Risk Score Egypt]",
              "VAR raw =",
              "    (0.45 * [Price Volatility 6M Egypt]) +",
              "    (0.35 * [Outlier Transaction Ratio Egypt]) +",
              "    (0.20 * [Shock Index Egypt])",
              "RETURN",
              "    IF(",
              "        (NOT ISBLANK(highest) || NOT ISBLANK(lowest)) && raw > 0,",
              "        1,",
              "        BLANK()",
              "    )"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Top 5 Combined Risk Egypt",
            "expression": [
              " ",
              "VAR highest = [Top 5 Highest Risk Score Egypt]",
              "VAR lowest = [Top 5 Lowest Risk Score Egypt]",
              "RETURN",
              "    IF(",
              "        NOT ISBLANK(highest) || NOT ISBLANK(lowest),",
              "        1,",
              "        BLANK()",
              "    )"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Top 5 Highest Risk Score Egypt",
            "expression": [
              " ",
              "VAR RawScore =",
              "    (0.45 * [Price Volatility 6M Egypt]) +",
              "    (0.35 * [Outlier Transaction Ratio Egypt]) +",
              "    (0.20 * [Shock Index Egypt])",
              "VAR MaxScoreInMarket =",
              "    MAXX(",
              "        ALLSELECTED('dim_area_egypt'),",
              "        (0.45 * [Price Volatility 6M Egypt]) +",
              "        (0.35 * [Outlier Transaction Ratio Egypt]) +",
              "        (0.20 * [Shock Index Egypt])",
              "    )",
              "VAR NormalizedScore =",
              "    DIVIDE(RawScore, MaxScoreInMarket, 0)",
              "VAR CurrentAreaRank =",
              "    RANKX(",
              "        FILTER(",
              "            ALLSELECTED('dim_area_egypt'),",
              "            (0.45 * [Price Volatility 6M Egypt]) +",
              "            (0.35 * [Outlier Transaction Ratio Egypt]) +",
              "            (0.20 * [Shock Index Egypt]) > 0",
              "        ),",
              "        DIVIDE(",
              "            (0.45 * [Price Volatility 6M Egypt]) +",
              "            (0.35 * [Outlier Transaction Ratio Egypt]) +",
              "            (0.20 * [Shock Index Egypt]),",
              "            MaxScoreInMarket,",
              "            0",
              "        ),",
              "        ,",
              "        DESC,",
              "        DENSE",
              "    )",
              "RETURN",
              "    IF(RawScore > 0 && CurrentAreaRank <= 5, NormalizedScore, BLANK())"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Top 5 Lowest Risk Score Egypt",
            "expression": [
              " ",
              "VAR RawScore =",
              "    (0.45 * [Price Volatility 6M Egypt]) +",
              "    (0.35 * [Outlier Transaction Ratio Egypt]) +",
              "    (0.20 * [Shock Index Egypt])",
              "VAR MaxScoreInMarket =",
              "    MAXX(",
              "        ALLSELECTED('dim_area_egypt'),",
              "        (0.45 * [Price Volatility 6M Egypt]) +",
              "        (0.35 * [Outlier Transaction Ratio Egypt]) +",
              "        (0.20 * [Shock Index Egypt])",
              "    )",
              "VAR NormalizedScore =",
              "    DIVIDE(RawScore, MaxScoreInMarket, 0)",
              "VAR ValidAreas =",
              "    FILTER(",
              "        ALLSELECTED('dim_area_egypt'),",
              "        NOT ISBLANK([Price Volatility 6M Egypt]) &&",
              "        NOT ISBLANK([Shock Index Egypt])",
              "    )",
              "VAR CurrentAreaRank =",
              "    RANKX(",
              "        ValidAreas,",
              "        DIVIDE(",
              "            (0.45 * [Price Volatility 6M Egypt]) +",
              "            (0.35 * [Outlier Transaction Ratio Egypt]) +",
              "            (0.20 * [Shock Index Egypt]),",
              "            MaxScoreInMarket,",
              "            0",
              "        ),",
              "        ,",
              "        ASC,",
              "        DENSE",
              "    )",
              "RETURN",
              "    IF(",
              "        NOT ISBLANK([Price Volatility 6M Egypt]) &&",
              "        NOT ISBLANK([Shock Index Egypt]) &&",
              "        CurrentAreaRank <= 5,",
              "        NormalizedScore,",
              "        BLANK()",
              "    )"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Top N Areas Filter Egypt",
            "expression": [
              " ",
              "VAR selected_n = SELECTEDVALUE('Top N'[N], 10)",
              "VAR area_rank =",
              "    RANKX(",
              "        ALL(dim_area_egypt[area_name_en]),",
              "        [Investor Score Egypt],",
              "        ,",
              "        DESC,",
              "        DENSE",
              "    )",
              "RETURN",
              "    IF(area_rank <= selected_n, 1, 0)"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Turnover Velocity Egypt",
            "expression": [
              "",
              "[Sales per Month Egypt]"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Capital Growth % Egypt",
            "expression": [
              "",
              "[YoY Price Growth % Egypt]"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Monthly Avg Price per sqm Egypt",
            "expression": [
              "",
              "CALCULATE([Avg Price per sqm Egypt])"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Price Volatility 6M Egypt",
            "expression": [
              "",
              "-- Note: Requires a 'YearMonth' column in dim_date_egypt",
              "VAR Window =",
              "    DATESINPERIOD(dim_date_egypt[full_date], MAX(dim_date_egypt[full_date]), -6, MONTH)",
              "RETURN",
              "STDEVX.S(",
              "    VALUES(dim_date_egypt[YearMonth]),",
              "    CALCULATE([Monthly Avg Price per sqm Egypt], Window)",
              ")"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Risk-Adjusted Opportunity Score Egypt",
            "expression": [
              "",
              "DIVIDE(",
              "    [Capital Growth % Egypt] * [Turnover Velocity Egypt],",
              "    [Price Volatility 6M Egypt]",
              ")"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Investor Score Egypt",
            "expression": " 0.80 * [Risk-Adjusted Opportunity Score Egypt] + 0.20 * DIVIDE([Avg Ticket Size Egypt], 5000000)",
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Avg Capital Growth % Egypt",
            "expression": [
              " ",
              "-- Note: Requires a 'YearMonth' column in dim_date_egypt",
              "AVERAGEX(VALUES(dim_date_egypt[YearMonth]), [Capital Growth % Egypt])"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Median Turnover Velocity Egypt",
            "expression": " MEDIANX(VALUES(dim_area_egypt[area_name_en]), [Turnover Velocity Egypt])",
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Avg Price per sqm 6M Egypt",
            "expression": [
              "",
              "AVERAGEX(",
              "    DATESINPERIOD(dim_date_egypt[full_date], MAX(dim_date_egypt[full_date]), -6, MONTH),",
              "    CALCULATE([Avg Price per sqm Egypt])",
              ")"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Shock Index Egypt",
            "expression": [
              "",
              "DIVIDE([Avg Price per sqm Egypt] - [Avg Price per sqm 6M Egypt], [Avg Price per sqm 6M Egypt])",
              "",
              "Outlier Transaction Ratio Egypt:=",
              "VAR mu = [Avg Price per sqm Egypt]",
              "VAR sigma =",
              "    CALCULATE(",
              "        STDEVX.S(",
              "            fact_transactions_egypt,",
              "            -- Update this column reference if you calculate price per meter dynamically",
              "            fact_transactions_egypt[meter_sale_price] ",
              "        )",
              "    )",
              "VAR threshold = mu + 2 * sigma",
              "VAR outliers =",
              "    CALCULATE(",
              "        [Transaction Count Egypt],",
              "        FILTER(",
              "            fact_transactions_egypt,",
              "            fact_transactions_egypt[meter_sale_price] > threshold",
              "        )",
              "    )",
              "RETURN",
              "    DIVIDE(outliers, [Transaction Count Egypt])"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          },
          {
            "name": "Outlier Transaction Ratio % Egypt",
            "expression": [
              "",
              "VAR mu = [Avg Price per sqm Egypt]",
              "VAR sigma =",
              "    CALCULATE(",
              "        STDEVX.S(",
              "            fact_transactions_egypt,",
              "            fact_transactions_egypt[meter_sale_price]",
              "        )",
              "    )",
              "VAR threshold = mu + 2 * sigma",
              "VAR outliers =",
              "    CALCULATE(",
              "        [Transaction Count Egypt],",
              "        FILTER(",
              "            fact_transactions_egypt,",
              "            fact_transactions_egypt[meter_sale_price] > threshold",
              "        )",
              "    )",
              "RETURN",
              "    FORMAT(DIVIDE(outliers, [Transaction Count Egypt]), \"0.00%\")"
            ],
            "annotations": [
              {
                "name": "TabularEditor_InPerspective",
                "value": "[\"Egypt\"]"
              }
            ]
          }
        ]
      },
