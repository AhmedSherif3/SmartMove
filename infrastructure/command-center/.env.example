# ==============================================================================
# SmartMove — Command Center (Server 3) Environment Variables
# COPY THIS FILE TO .env AND FILL IN REAL VALUES ON THE SERVER
# ==============================================================================

# ── Object Storage (Mimir, Loki, Tempo) ──
# Note: S3_ENDPOINT will eventually be your Server 4 MinIO Tailscale IP (e.g., http://100.64.0.4:9000)
AZURE_STORAGE_ACCOUNT=smartmoveobservability123
AZURE_STORAGE_KEY=replace_with_azure_storage_key
AZURE_STORAGE_CONTAINER=smartmove-observability

# ── Grafana ──
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=your_secure_grafana_password
GF_ROOT_URL=http://localhost:3100

# ── Cloudflare Exporter ──
CF_API_EMAIL=your_cloudflare_email@example.com
CF_API_KEY=your_cloudflare_global_api_key

# ── Marquez Data Lineage ──
MARQUEZ_DB_PASSWORD=your_secure_marquez_db_password

# ── Wazuh SIEM ──
WAZUH_INDEXER_PASSWORD=your_wazuh_indexer_password
WAZUH_ADMIN_PASSWORD=your_wazuh_dashboard_password

# ── Alertmanager ──
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Cache Node Tailscale IPs (Micro-VMs 4, 5, 6) ──
TEMPO_CACHE_IP=100.x.x.24
MIMIR_CACHE_IP=100.x.x.25
LOKI_CACHE_IP=100.x.x.26